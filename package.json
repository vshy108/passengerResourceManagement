{
  "name": "passenger-resource-management",
  "version": "1.0.0",
  "private": true,
  "description": "Spaceship X26 Passenger Resource Management System",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "npm run build && node dist/interface/cli.js",
    "demo": "npm run build && node dist/interface/cli.js",
    "serve": "npm run build && node dist/interface/serve.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.5"
  }
}
